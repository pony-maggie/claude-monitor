#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV_DIR="$SCRIPT_DIR/.venv"
PID_FILE="$SCRIPT_DIR/.exporter.pid"
EXPORTER_PORT=9091

# ── Helpers ───────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
Usage: ccmon [options]
  ccmon              Start monitoring stack + exporter
  ccmon stop         Stop exporter + Docker stack
  ccmon -c | --claude  Also launch Claude Code after starting
  ccmon -h | --help    Show this help
EOF
}

ensure_venv() {
  if [[ ! -d "$VENV_DIR" ]]; then
    echo "Creating Python venv..."
    python3 -m venv "$VENV_DIR"
  fi
  # Install/upgrade deps if needed
  "$VENV_DIR/bin/pip" install -q -r "$SCRIPT_DIR/requirements.txt"
}

start_exporter() {
  # Kill stale process if PID file exists
  if [[ -f "$PID_FILE" ]]; then
    local old_pid
    old_pid=$(cat "$PID_FILE")
    if kill -0 "$old_pid" 2>/dev/null; then
      echo "Exporter already running (PID $old_pid)."
      return
    else
      rm -f "$PID_FILE"
    fi
  fi

  ensure_venv
  echo "Starting Claude JSONL exporter on :${EXPORTER_PORT}..."
  "$VENV_DIR/bin/python" "$SCRIPT_DIR/claude_exporter.py" &
  local pid=$!
  echo "$pid" > "$PID_FILE"
  echo "Exporter started (PID $pid)."
}

stop_exporter() {
  if [[ -f "$PID_FILE" ]]; then
    local pid
    pid=$(cat "$PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
      echo "Stopping exporter (PID $pid)..."
      kill "$pid"
      # Wait up to 5s for graceful shutdown
      for _ in {1..10}; do
        kill -0 "$pid" 2>/dev/null || break
        sleep 0.5
      done
      kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null
    fi
    rm -f "$PID_FILE"
    echo "Exporter stopped."
  else
    echo "No exporter PID file found."
  fi
}

stop_all() {
  stop_exporter
  echo "Stopping Docker stack..."
  docker compose -f "$SCRIPT_DIR/docker-compose.yml" down
  echo "All stopped."
}

# ── Main ──────────────────────────────────────────────────────────────────

LAUNCH_CLAUDE=false

case "${1:-}" in
  stop)
    stop_all
    exit 0
    ;;
  -h|--help)
    usage
    exit 0
    ;;
  -c|--claude)
    LAUNCH_CLAUDE=true
    shift
    ;;
esac

# 1. Start Docker stack
echo "Starting monitoring stack (Prometheus + Grafana)..."
docker compose -f "$SCRIPT_DIR/docker-compose.yml" up -d

# 2. Wait for Grafana to be ready
echo "Waiting for services..."
for _ in {1..15}; do
  if curl -sf http://localhost:3000/api/health > /dev/null 2>&1; then
    echo "Services are ready."
    break
  fi
  sleep 1
done

# 3. Start exporter
start_exporter

# 4. Open Grafana
if [[ "$(uname)" == "Darwin" ]]; then
  open "http://localhost:3000/d/claude-monitor/claude-code-monitor?refresh=30s"
else
  xdg-open "http://localhost:3000/d/claude-monitor/claude-code-monitor?refresh=30s" 2>/dev/null || echo "Grafana: http://localhost:3000/d/claude-monitor/claude-code-monitor?refresh=30s"
fi

echo ""
echo "Monitoring is running:"
echo "  Exporter:   http://localhost:${EXPORTER_PORT}/metrics"
echo "  Prometheus: http://localhost:9090"
echo "  Grafana:    http://localhost:3000/d/claude-monitor/claude-code-monitor?refresh=30s"
echo ""
echo "To stop: ccmon stop"

# 5. Optionally launch Claude Code
if [[ "$LAUNCH_CLAUDE" == true ]]; then
  echo ""
  echo "Launching Claude Code..."
  exec claude "$@"
fi
